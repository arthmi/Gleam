{
    "name": "ambilight",
    "version": "1.0.0",
    "display_name": "Ambilight",
    "description": "Reproduces on-screen edge colors on LED groups mapped to screen sides",
    "entry": "main.py",
    "class": "AmbilightModule",
    "requirements": "requirements.txt",
    "parameters": [
        {
            "name": "device_index",
            "type": "int",
            "default": 0,
            "description": ""
        },
        {
            "name": "edge",
            "type": "str",
            "default": null,
            "description": ""
        },
        {
            "name": "reversed",
            "type": "bool",
            "default": false,
            "description": ""
        },
        {
            "name": "band_depth_percent",
            "type": "float",
            "default": 0.20,
            "description": ""
        },
        {
            "name": "weight_exponent",
            "type": "int",
            "default": 1,
            "description": ""
        },
        {
            "name": "blur_sigma",
            "type": "float",
            "default": 1.5,
            "description": ""
        }
    ]
}
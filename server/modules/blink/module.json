{
    "name": "blink",
    "version": "1.0.0",
    "description": "A blinking light module",
    "entry": "main.py",
    "class": "BlinkModule",
    "requirements": null,
    "parameters": [
        {
            "name": "delay",
            "type": "int",
            "default": 1,
            "description": "Blink interval in milliseconds"
        },
        {
            "name": "main_intensity",
            "type": "float",
            "default": 1.0,
            "description": "Minimum brightness level for the LED [0.0 - 1.0]"
        },
        {
            "name": "secondary_intensity",
            "type": "float",
            "default": 0.0,
            "description": "Maximum brightness level for the LED [0.0 - 1.0]"
        },
        {
            "name": "main_color",
            "type": "ColorModel",
            "default": {
                "r": 255,
                "g": 255,
                "b": 255
            },
            "description": "Main color for the LED"
        },
        {
            "name": "secondary_color",
            "type": "ColorModel",
            "default": {
                "r": 0,
                "g": 0,
                "b": 0
            },
            "description": "Secondary color for the LED"
        },
        {
            "name": "main_white",
            "type": "float",
            "default": 1.0,
            "description": "Main white brightness for the LED [0.0 - 1.0]"
        },
        {
            "name": "secondary_white",
            "type": "float",
            "default": 0.0,
            "description": "Secondary white brightness for the LED [0.0 - 1.0]"
        }
    ]
}